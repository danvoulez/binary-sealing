    "resolution_state": {"type": "string"},
    "selected_diamond_id": {"type": ["string", "null"]},
    "selected_manifest_path": {"type": ["string", "null"]},
    "candidates": {"type": "array", "items": {"type": "object"}},
    "access_request_hint": {"type": ["object", "null"]},
    "resolution_path": {"type": "string"},
    "created_at": {"type": "string"}
  }
}
