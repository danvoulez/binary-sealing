{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "act",
  "type": "object",
  "required": ["who", "did", "this", "when", "status"],
  "properties": {
    "who": {"type": "string"},
    "did": {"type": "string"},
    "this": {"type": "string"},
    "when": {"type": "string", "format": "date-time"},
    "confirmed_by": {"type": ["string", "null"]},
    "if_ok": {"type": ["string", "null"]},
    "if_doubt": {"type": ["string", "null"]},
    "if_not": {"type": ["string", "null"]},
    "status": {"type": "string"},
    "aux": {"type": "object"}
  }
}
